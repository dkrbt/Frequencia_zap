# --- CONFIGURAÇÕES DO FREQUENCIA_ZAP (EXEMPLO) ---
# Renomeie este arquivo para .env e preencha com seus dados reais.

# API da Escola (Opcional - Se disponível na sua rede)
SCHOOL_API_URL=https://api.escola.com/presenca
SCHOOL_API_TOKEN=seu_token_aqui

# Evolution API (WhatsApp Docker)
# Se estiver no Windows usando o docker original, localhost:8081 deve funcionar após a última alteração.
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_TOKEN=sua_chave_global_d
EVOLUTION_INSTANCE=cedom_bot

# SIAP (Portal da Educação de Goiás)
SIAP_USER=seu_cpf_apenas_numeros
SIAP_PASS=sua_senha_do_siap

# Credenciais de Acesso ao Painel Web (Streamlit)
ADMIN_PASSWORD=defina_uma_senha_mestre_segura

# Configurações de Banco de Dados (Gerenciado Automaticamente)
DB_PATH=database/escola.db
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Docker Postgres (Usado pela Evolution API)
POSTGRES_PASSWORD=senha_do_banco_postgres_cedom
AUTHENTICATION_API_KEY=sua_chave_global_d
