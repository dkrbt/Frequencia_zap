# Exemplo de arquivo .env
# Copie este arquivo para .env e preencha com os valores reais

# API da Escola
SCHOOL_API_URL=https://api.escola.com/presenca
SCHOOL_API_TOKEN=seu_token_aqui

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://api.evolution.com/send
EVOLUTION_API_TOKEN=seu_token_evolution
EVOLUTION_INSTANCE=sua_instancia

# Banco de dados
DB_PATH=database/logs.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log